#!/bin/bash

# --- Appearance Configuration ---
FG_COLOR="c0caf5ff"
WRONG_COLOR="db4b4bff"
VERIFY_COLOR="7aa2f7ff"
FONT="JetBrains Mono"

# --- Assets & Paths ---
LOCK_IMAGE="$HOME/Images/screen-lock.png"
TEMP_IMAGE="/tmp/i3lock_prepared.png"

# --- Pre-Lock Actions ---
# Force US layout to avoid password entry errors
setxkbmap us

# Prepare background image if not exists
if [ ! -f "$TEMP_IMAGE" ] && [ -f "$LOCK_IMAGE" ]; then
    magick "$LOCK_IMAGE" -resize 1366x768^ -gravity center -extent 1366x768 "$TEMP_IMAGE"
fi

BG_ARG=(-i "$TEMP_IMAGE")
if [ ! -f "$TEMP_IMAGE" ]; then
    BG_ARG=(-c "1a1b26")
fi

# --- Execution ---
i3lock -n --force-clock \
    "${BG_ARG[@]}" \
    -e --indicator \
    --radius=20 \
    --ring-width=40 \
    --pointer=default \
    --refresh-rate=0 \
    --pass-media-keys \
    --line-uses-inside \
    \
    --inside-color="$FG_COLOR" \
    --ring-color="$FG_COLOR" \
    --insidever-color="$VERIFY_COLOR" \
    --ringver-color="$VERIFY_COLOR" \
    --insidewrong-color="$WRONG_COLOR" \
    --ringwrong-color="$WRONG_COLOR" \
    --keyhl-color="$VERIFY_COLOR" \
    --separator-color="$VERIFY_COLOR" \
    --bshl-color="$VERIFY_COLOR" \
    \
    --time-str="%H:%M" \
    --time-size=100 \
    --time-pos="650:375" \
    --time-color="FFFFFFFF" \
    --time-font="$FONT:style=Bold" \
    \
    --date-str="%a, %d %b" \
    --date-size=45 \
    --date-pos="650:425" \
    --date-color="FFFFFFFF" \
    --date-font="$FONT:style=Bold" \
    \
    --greeter-text="Type the password to Unlock" \
    --greeter-size=23 \
    --greeter-pos="650:900" \
    --greeter-color="$FG_COLOR" \
    --greeter-font="$FONT" \
    \
    --verif-text="Verifying Password..." \
    --verif-size=23 \
    --verif-pos="650:900" \
    --verif-color="$VERIFY_COLOR" \
    --verif-font="$FONT" \
    \
    --wrong-text="Wrong Password!" \
    --wrong-size=23 \
    --wrong-pos="650:475" \
    --wrong-color="$WRONG_COLOR" \
    --wrong-font="$FONT" \
    \
    --ind-pos="650:760" \
    --noinput-text=""

# --- Post-Unlock Actions ---
# Restore US/RU layouts and Alt+Shift toggle
setxkbmap -layout us,ru -option grp:alt_shift_toggle
