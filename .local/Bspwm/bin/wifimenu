#!/usr/bin/env bash

# --- Global Configuration ---
readonly WIFI_IFACE="wlp2s0"
readonly ETH_IFACE="enp1s0f1"
readonly ROFI_BASE="rofi -dmenu -i -selected-row 0"
readonly CONN_TIMEOUT=10

# --- Helper Functions ---
check_connection() {
    local target_ssid="$1"
    sleep 3
    local active_now
    active_now=$(nmcli -t -f NAME,DEVICE connection show --active | grep ":$WIFI_IFACE$" | cut -d: -f1)
    [[ "$active_now" == "$target_ssid" ]]
}

# --- Pre-flight Checks ---
systemctl is-active --quiet NetworkManager || pkexec systemctl start NetworkManager

# --- Data Acquisition ---
current_ssid=$(nmcli -t -f NAME,DEVICE connection show --active | grep ":$WIFI_IFACE$" | cut -d: -f1)
mapfile -t saved_connections < <(nmcli -t -f NAME,TYPE connection show | awk -F: '$2=="802-11-wireless" {print $1}')
available_raw=$(nmcli -t -f "SECURITY,SSID" device wifi list ifname "$WIFI_IFACE" | sed 's/^--//' | sort -u)

# --- Build Rofi Menu ---
options=()

# 1. Active connection
[[ -n "$current_ssid" ]] && options+=("󰖩  $current_ssid (Active)")

# 2. Saved connections
for ssid in "${saved_connections[@]}"; do
    [[ -z "$ssid" || "$ssid" == "$current_ssid" ]] && continue
    options+=("  $ssid")
done

# 3. Available networks in range
while IFS=: read -r security ssid; do
    [[ -z "$ssid" ]] && continue
    if [[ ! " ${options[*]} " =~ " $ssid " ]]; then
        icon=" "
        [[ "$security" =~ "WPA" ]] && icon=" "
        options+=("$icon $ssid")
    fi
done <<< "$available_raw"

# --- User Selection ---
eth_state=$(nmcli -t -f DEVICE,STATE dev | grep "^$ETH_IFACE:" | cut -d: -f2)
eth_icon=$([[ "$eth_state" == "connected" ]] && echo "󰈁" || echo "󰈂")

chosen_network=$(printf '%s\n' "${options[@]}" | $ROFI_BASE -p "($eth_icon) Wi-Fi:")
[[ -z "$chosen_network" ]] && exit 0

chosen_id=$(echo "$chosen_network" | sed -E 's/^[󰖩 ]*//; s/ \(Active\)//' | xargs)

# --- Connection Range Validation ---
if [[ "$chosen_network" != *"(Active)"* ]]; then
    if ! echo "$available_raw" | grep -q ":$chosen_id$"; then
        notify-send "Error" "Network '$chosen_id' is not in range" -u critical
        exit 1
    fi
fi

# --- Active Network Submenu ---
if [[ "$chosen_network" == *"(Active)"* ]]; then
    action=$(echo -e "󰑐 Reconnect\n󰅖 Disconnect" | $ROFI_BASE -p "Action for $chosen_id:")
    
    case "$action" in
        *Reconnect)
            notify-send "Wi-Fi" "Reconnecting to $chosen_id..."
            nmcli device disconnect "$WIFI_IFACE" >/dev/null 2>&1
            sleep 1
            nmcli --wait $CONN_TIMEOUT connection up id "$chosen_id" >/dev/null 2>&1
            
            if check_connection "$chosen_id"; then
                notify-send "Wi-Fi" "Successfully reconnected to $chosen_id" -i network-transmit-receive
            else
                notify-send "Error" "Reconnect to $chosen_id failed" -u critical -i network-error
            fi
            exit 0 ;;
            
        *Disconnect)
            nmcli device disconnect "$WIFI_IFACE"
            notify-send "Wi-Fi" "Disconnected from $chosen_id"
            exit 0 ;;
            
        *) exit 0 ;;
    esac
fi

# --- Connection Logic ---
nmcli device set "$WIFI_IFACE" managed yes
notify-send "Wi-Fi" "Connecting to $chosen_id..."

if printf '%s\n' "${saved_connections[@]}" | grep -qx "$chosen_id"; then
    nmcli --wait $CONN_TIMEOUT connection up id "$chosen_id" >/dev/null 2>&1
elif [[ "$chosen_network" == ""* ]]; then
    wifi_password=$($ROFI_BASE -p "Password for $chosen_id: ")
    [[ -z "$wifi_password" ]] && exit 0
    nmcli --wait $CONN_TIMEOUT device wifi connect "$chosen_id" password "$wifi_password" >/dev/null 2>&1
else
    nmcli --wait $CONN_TIMEOUT device wifi connect "$chosen_id" >/dev/null 2>&1
fi

# --- Final Validation ---
if check_connection "$chosen_id"; then
    notify-send "Wi-Fi" "Connected to $chosen_id"
else
    notify-send "Error" "Connection to $chosen_id failed" -u critical
    nmcli device disconnect "$WIFI_IFACE" >/dev/null 2>&1
fi
