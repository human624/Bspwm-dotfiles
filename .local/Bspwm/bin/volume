#!/usr/bin/env bash

# Unique ID to replace the same notification bubble instead of stacking them
NOTIFY_ID=9999

notify() {
    # -r: replaces the notification with the same ID
    # -t: timeout in milliseconds
    # -u low: prevents the notification from interrupting "Do Not Disturb" modes
    notify-send -u low -r "$NOTIFY_ID" -t 800 "$1" "$2"
}

# Volume controls
volume_up() {
    pamixer -i 5 --unmute
    notify "Volume" "$(pamixer --get-volume)%"
}

volume_down() {
    pamixer -d 5 --unmute
    notify "Volume" "$(pamixer --get-volume)%"
}

toggle_mute() {
    pamixer -t
    if pamixer --get-mute; then
        notify "Volume" "Muted"
    else
        notify "Volume" "$(pamixer --get-volume)%"
    fi
}

# Brightness controls
brightness_up() {
    brightnessctl s +5% > /dev/null
    notify "Brightness" "$(brightnessctl -m | cut -d, -f4)"
}

brightness_down() {
    # Decrease brightness, but prevents reaching 0% (optional safety)
    brightnessctl s 5%- > /dev/null
    notify "Brightness" "$(brightnessctl -m | cut -d, -f4)"
}

# Command Dispatcher
case "${1:-}" in
    volume-up)        volume_up ;;
    volume-down)      volume_down ;;
    toggle-mute)      toggle_mute ;;
    brightness-up)    brightness_up ;;
    brightness-down)  brightness_down ;;
    *)
        echo "Usage: $0 {volume-up|volume-down|toggle-mute|brightness-up|brightness-down}"
        exit 1
        ;;
esac
