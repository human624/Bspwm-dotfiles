#
# Main actions
#

# Reload sxhkd configuration:
super + Escape + r
    pkill -USR1 -x sxhkd; notify-send 'sxhkd' 'Config restarted' -t 1500
	
# Launch terminal
super + Return
    alacritty

# Show/Hide Polybar
super + p
	sh $HOME/.local/Bspwm/bin/toggle-polybar

# Set random wallpaper
super + w
	sh $HOME/.local/Bspwm/bin/random_wallpaper

# Change language
Alt_L + shift
	sh $HOME/.local/Bspwm/bin/change_language.sh

Shift_L + alt
	sh $HOME/.local/Bspwm/bin/change_language.sh
    
# Open rofi menu
super + d
    {rofi -show drun}
    
super + x
    {sh $HOME/.local/Bspwm/bin/powermenu}

# Launch applications
super + shift + {f,n,p,i,l,x}
	{firefox, \
	thunar, \
	pavucontrol, \
	firefox --private-window, \
	sh $HOME/.local/Bspwm/bin/screen-lock, \
	sh $HOME/.local/Bspwm/bin/xcolor-pick}
     
# Change volume via fn    
XF86AudioRaiseVolume
    sh $HOME/.local/Bspwm/bin/volume volume-up

XF86AudioLowerVolume
    sh $HOME/.local/Bspwm/bin/volume volume-down

XF86AudioMute
    sh $HOME/.local/Bspwm/bin/volume toggle-mute

# Change brightness via fn 
XF86MonBrightnessUp
    sh $HOME/.local/Bspwm/bin/volume brightness-up

XF86MonBrightnessDown
    sh $HOME/.local/Bspwm/bin/volume brightness-down

# Pause/Play (global)
XF86AudioPlay
    echo 'cycle pause' | socat - /tmp/mpvsocket

# Next track/video
XF86AudioNext
    echo 'playlist-next' | socat - /tmp/mpvsocket

# Previous track/video
XF86AudioPrev
    echo 'playlist-prev' | socat - /tmp/mpvsocket

# Screenshot
Print
    flameshot gui

#
# BSPWM hotkeys
#

# Quit/Restart bspwm
ctrl + shift + {q,r}
    bspc {quit,wm -r}

# Force close window
super + c
    bspc node -c

# Toggle between tiled and monocle mode
super + space
	bspc node -t "~"{floating,tiled}

#
# State/Flags
#

# Set window state
super + {t,ctrl + t,f}
	bspc node -t {tiled,pseudo_tiled,fullscreen}
	

# Switch to next window including floating
alt + {_,shift + }Tab
    bspc node -f {next.local,prev.local}

#
# Focus/Swap
#

# Focus the last window/desktop
super + {grave,Tab}
	bspc {node,desktop} -f last

# Send the current window to the given desktop
super + {_,shift + }{1-9,0}
	bspc {desktop -f,node -d} '^{1-9,10}'

#
# Preselection
#

# Preselect ratio
super + ctrl + {1-9}
	bspc node -o 0.{1-9}

# Cancel preselection for the focused node
super + ctrl + space
	bspc node -p cancel

# Cancel preselection for the focused desktop
super + ctrl + shift + space
	bspc query -N -d | xargs -I id -n 1 bspc node id -p cancel

#
# Move/resize
#

# Expand window
super + ctrl + {h,j,k,l}
    bspc node -z {left -20 0,bottom 0 20,top 0 -20,right 20 0}

# Send window to another edge of the screen
super + {_,alt + }{h,j,k,l}
    bspc node -{f,s} {west,south,north,east}

# Set window flags
super + ctrl + {m,x,y,z}
	bspc node -g {marked,locked,sticky,private}

# Swap the current window with the biggest window
super + g
	bspc node -s biggest.window
